# Copy to supabase/.env.local (gitignored) for `supabase functions serve`
# NEVER commit supabase/.env.local

# Supabase injects these automatically when deployed; set locally for function serve.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<local anon key from supabase start>

# job-application-ai
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# cloud-storage-google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_API_KEY=

# cloud-storage-box
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
