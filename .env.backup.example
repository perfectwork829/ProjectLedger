# Copy to .env.backup (gitignored) for scripts/backup-supabase.ps1
# NEVER commit .env.backup — it may contain secrets.

SUPABASE_PROJECT_REF=udxgnisxhcnhzrndnmdc
SUPABASE_URL=https://udxgnisxhcnhzrndnmdc.supabase.co

# Required for DB backup without Docker (Dashboard - Settings - Database - Database password)
SUPABASE_DB_PASSWORD=

# Dashboard - Project Settings - API - service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Optional - session pooler host (IPv4-friendly; auto-detected if you ran supabase link)
# SUPABASE_DB_POOLER_HOST=aws-1-us-east-2.pooler.supabase.com

# Optional full URI (use Session pooler URI from Dashboard - NOT Direct connection)
# Direct db.*.supabase.co is IPv6-only and often fails on Windows; the script auto-upgrades to pooler when possible.
# SUPABASE_DB_URL=postgresql://postgres.udxgnisxhcnhzrndnmdc:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Storage bucket used by the app (default: account-files)
SUPABASE_STORAGE_BUCKET=account-files
